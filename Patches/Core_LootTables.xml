                    <options>
                        <li>
                            <weight>50</weight>
                            <thingSetMaker Class="ThingSetMaker_Count">
                                <fixedParams>
                                    <filter>
                                        <thingDefs>
                                            <li>AncientBookPoor</li>
                                        </thingDefs>
                                    </filter>
                                    <countRange>1~2</countRange>
                                </fixedParams>
                            </thingSetMaker>
                        </li>
                        <li>
                            <weight>30</weight>
                            <thingSetMaker Class="ThingSetMaker_Count">
                                <fixedParams>
                                    <filter>
                                        <thingDefs>
                                            <li>AncientBookNormal</li>
                                        </thingDefs>
                                    </filter>
                                    <countRange>1~2</countRange>
                                </fixedParams>
                            </thingSetMaker>
                        </li>
                        <li>
                            <weight>15</weight>
                            <thingSetMaker Class="ThingSetMaker_Count">
                                <fixedParams>
                                    <filter>
                                        <thingDefs>
                                            <li>AncientBookGood</li>
                                        </thingDefs>
                                    </filter>
                                    <countRange>1</countRange>
                                </fixedParams>
                            </thingSetMaker>
                        </li>
                        <li>
                            <weight>5</weight>
                            <thingSetMaker Class="ThingSetMaker_Count">
                                <fixedParams>
                                    <filter>
                                        <thingDefs>
                                            <li>AncientBookExcellent</li>
                                        </thingDefs>
                                    </filter>
                                    <countRange>1</countRange>
                                </fixedParams>
                            </thingSetMaker>
                        </li>
                    </options>
                </thingSetMaker>
            </li>
        </value>
    </Operation>
</Patch>